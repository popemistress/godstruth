{
  "name": "godstruth",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "bibles:upload": "tsx --env-file=.env.local scripts/upload-bibles.ts",
    "epub-bibles:upload": "tsx --env-file=.env.local scripts/upload-epub-bibles.ts",
    "covers:extract": "tsx --env-file=.env.local scripts/extract-epub-covers.ts",
    "others:upload": "tsx --env-file=.env.local scripts/upload-others.ts",
    "pdf-covers:extract": "tsx --env-file=.env.local scripts/extract-pdf-covers.ts",
    "ancient:upload": "tsx --env-file=.env.local scripts/upload-ancient-bibles.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@auth/prisma-adapter": "^2.7.2",
    "@hookform/resolvers": "^3.9.1",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@stripe/stripe-js": "^4.9.0",
    "@tanstack/react-query": "^5.62.2",
    "@types/howler": "^2.2.12",
    "@uploadthing/react": "^7.3.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.13.1",
    "howler": "^2.2.4",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "next": "14.2.29",
    "next-auth": "^5.0.0-beta.25",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.1",
    "react-reader": "^2.0.15",
    "resend": "^4.0.1",
    "sharp": "^0.33.5",
    "stripe": "^17.4.0",
    "swiper": "^12.1.3",
    "tailwind-merge": "^2.5.5",
    "uploadthing": "^7.4.4",
    "yet-another-react-lightbox": "^3.30.1",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
